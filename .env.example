# Copy this file to .env and fill in your real API keys.

# REST Countries (no key needed — free public API)
RESTCOUNTRIES_BASE_URL=https://restcountries.com/v3.1

# OpenTripMap — get your key at https://opentripmap.io/
OPENTRIPMAP_BASE_URL=https://api.opentripmap.com/0.1/en
OPENTRIPMAP_API_KEY=your_opentripmap_key_here

# WeatherAPI — BONUS feature, get your key at https://www.weatherapi.com/
# Leave blank to skip weather display (app handles this gracefully)
WEATHERAPI_BASE_URL=http://api.weatherapi.com/v1
WEATHERAPI_KEY=